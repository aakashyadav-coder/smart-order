# Smart Order — Client Environment Variables
# Copy this to .env.local for local development (never commit .env.local)

# ───────────────────────────────
# API & Socket (Production only)
# In development, Vite proxy handles both → leave these EMPTY or unset
# ───────────────────────────────

# Your deployed backend URL (no trailing slash)
# Example: https://smart-order-api.railway.app
VITE_API_URL=

# Your deployed backend URL for Socket.io (same as API URL usually)
# Example: https://smart-order-api.railway.app
VITE_SOCKET_URL=
