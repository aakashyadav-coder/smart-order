# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/smart_order"

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# Twilio (optional - leave empty to use console mock)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Client URL for CORS
CLIENT_URL=http://localhost:5173

# Optional: Seed users (set both email + password for each to create)
SEED_SUPER_EMAIL=
SEED_SUPER_PASSWORD=
SEED_SUPER_NAME=
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
SEED_OWNER_NAME=
SEED_KITCHEN_EMAIL=
SEED_KITCHEN_PASSWORD=
SEED_KITCHEN_NAME=

# Optional: Super admin creation helper (createSuperAdmin.js)
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=
